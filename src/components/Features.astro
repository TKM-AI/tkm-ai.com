---
interface Feature { icon: string; title: string; desc: string; tags?: string[]; }
interface Props { id?: string; eyebrow?: string; title?: string; intro?: string; features?: Feature[]; }

const DEFAULTS: Feature[] = [
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v12M6 21a3 3 0 100-6 3 3 0 000 6zM18 9a3 3 0 100-6 3 3 0 000 6zM18 9c0 6-12 4-12 6"/></svg>',
    title: 'Adaptive routing',
    desc: 'Route each request to the right model by cost, latency, and capability — and fail over automatically.',
    tags: ['multi-model', 'auto-failover'],
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.9 4.9l2.8 2.8M16.3 16.3l2.8 2.8M2 12h4M18 12h4M4.9 19.1l2.8-2.8M16.3 7.7l2.8-2.8"/></svg>',
    title: 'Cost optimization',
    desc: 'Compress prompts, cache aggressively, and trim wasted tokens automatically — without touching your agent logic.',
    tags: ['prompt compression', 'semantic cache'],
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l3-4 3 3 4-6"/></svg>',
    title: 'Observability & eval',
    desc: 'Trace every step, score quality with custom evals, and catch regressions before they reach a user.',
    tags: ['tracing', 'eval suites'],
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 12l9 4 9-4M3 17l9 4 9-4"/></svg>',
    title: 'Efficient deployment',
    desc: 'Push an agent and we autoscale it across regions with sub-second cold starts. No infra to babysit.',
    tags: ['autoscale', 'edge deploy'],
  },
];

const {
  id = 'product',
  eyebrow = 'The platform',
  title = 'Everything you need to run agents in production',
  intro = 'One platform to optimize, deploy, and observe LLM-based agents — so your team ships quality without burning budget.',
  features = DEFAULTS,
} = Astro.props;
---
<section class="section wrap" id={id}>
  <div class="sec-head reveal">
    <span class="eyebrow">{eyebrow}</span>
    <h2>{title}</h2>
    <p>{intro}</p>
  </div>
  <div class="feat-grid">
    {features.map((f) => (
      <div class="feat reveal">
        <div class="ico" set:html={f.icon} />
        <h3>{f.title}</h3>
        <p>{f.desc}</p>
        {f.tags && <div class="tags">{f.tags.map((t) => <span>{t}</span>)}</div>}
      </div>
    ))}
  </div>
</section>
