---
const products = [
  { href: '/uniro', label: 'Uniro' },
  { href: '/papermentor', label: 'PaperMentor' },
];
const company = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '#contact', label: 'Contact' },
  { href: 'mailto:hello@tkm-ai.com', label: 'Email us' },
];
---
<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <a class="brand" href="/"><span class="mark"></span>TKM-AI</a>
        <p>The company building the tools that take AI agents from prototype to scale — optimized, deployed, and observed.</p>
      </div>
      <div class="foot-col">
        <h5>Products</h5>
        {products.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="foot-col">
        <h5>Company</h5>
        {company.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; 2026 TKM-AI</span>
      <span>tkm-ai.com</span>
    </div>
  </div>
</footer>
