---
// Shared top nav across the company home + product pages.
// Links point at real routes; the "Get in touch" CTA scrolls to the current page's #contact band.
const links = [
  { href: '/uniro', label: 'Uniro' },
  { href: '/papermentor', label: 'PaperMentor' },
  { href: '/blog', label: 'Blog' },
];
---
<header class="nav">
  <div class="wrap nav-inner">
    <a class="brand" href="/"><span class="mark"></span>TKM-AI</a>
    <nav class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="nav-cta">
      <a href="#contact" class="btn btn-primary">Get in touch</a>
    </div>
  </div>
</header>
