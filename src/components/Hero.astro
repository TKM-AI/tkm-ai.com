---
import SavingsChart from './SavingsChart.astro';
---
<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <span class="pill"><span class="tag">AI</span> Built for production LLM agents</span>
      <h1 class="hero-title">Ship AI agents that are <span class="accent">fast, cheap, and reliable.</span></h1>
      <p class="hero-sub">TKM-AI helps teams optimize and deploy LLM-based agents — cutting latency and cost while keeping quality high. From prototype to production.</p>
      <div class="hero-actions">
        <a href="/#contact" class="btn btn-primary">Get in touch <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></a>
        <a href="/#how" class="btn btn-secondary">See how it works</a>
      </div>
      <div class="hero-note"><span class="dot"></span> Working with early teams building LLM agents</div>
    </div>
    <div class="hero-visual">
      <SavingsChart />
    </div>
  </div>
</section>
