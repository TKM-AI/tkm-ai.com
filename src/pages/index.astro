---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import HomeHero from '../components/HomeHero.astro';
import TrustMarquee from '../components/TrustMarquee.astro';
import StatsBand from '../components/StatsBand.astro';
import ProductsShowcase from '../components/ProductsShowcase.astro';
import HowItWorks from '../components/HowItWorks.astro';
import About from '../components/About.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const approachSteps = [
  { n: '01', title: 'Optimize', desc: 'Compress, cache, and route every request so your agents run lean — without touching their logic.' },
  { n: '02', title: 'Deploy', desc: 'Ship to autoscaling infrastructure in one step, from prototype to global production.' },
  { n: '03', title: 'Observe', desc: 'Trace every run, score quality with evals, and catch regressions before your users do.' },
];

const companyFacts = [
  { k: 'Team', v: 'Researchers & engineers' },
  { k: 'What we build', v: 'Tools for AI agents' },
  { k: 'Products', v: 'Uniro · PaperMentor' },
  { k: 'What we tackle', v: 'Cost · Latency · Reliability' },
];
const companyValues = [
  { title: 'Research-driven', desc: 'Our team advances the methods behind efficient, reliable agents — research rigor, shipped into products.' },
  { title: 'Cost-aware by default', desc: 'Every optimization is measured against quality, not just price — so you never trade accuracy for a lower bill.' },
  { title: 'Production-first', desc: 'Tracing, evaluations, and automatic failover are built in from day one, not bolted on later.' },
  { title: 'Model-agnostic', desc: "Route across providers and models — you're never locked into a single vendor." },
];
---
<BaseLayout>
  <Nav />
  <main>
    <HomeHero />
    <TrustMarquee />
    <StatsBand />
    <ProductsShowcase />
    <HowItWorks
      eyebrow="Our approach"
      title="How TKM-AI takes agents to scale"
      intro="One backbone — optimize, deploy, observe — powers every product we build."
      steps={approachSteps}
    />
    <About
      title="Built by researchers and engineers obsessed with how agents run"
      lead="TKM-AI brings together researchers and engineers — people advancing the techniques behind efficient, reliable agents, not just wiring up what already exists. We pair frontier research with production engineering so AI agents are cheaper, faster, and more dependable to run, from prototype to scale."
      facts={companyFacts}
      values={companyValues}
    />
    <CTA
      title="Let's build agents the world can rely on"
      subtitle="Tell us what you're building and we'll point you to the right tool."
      mailSubject="TKM-AI — hello"
      mailBody={"Hi TKM-AI team,\n\nI'd like to learn more about what you're building.\n\n"}
    />
  </main>
  <Footer />
</BaseLayout>
